time_min)) +\n  geom_point(size = 3) +\n  geom_smooth(method = \"lm\") +\n  theme_minimal() +\n  labs(\n    title = \"Total Soundtrack Runtime Over Time\",\n    x = \"Year\",\n    y = \"Runtime (minutes)\"\n  )\n```\n\n::: {.cell-output .cell-output-stderr}\n\n```\n`geom_smooth()` using formula = 'y ~ x'\n```\n\n\n:::\n\n::: {.cell-output-display}\n![](Quarto_website_files/figure-html/unnamed-chunk-5-1.png){width=672}\n:::\n:::\n\n\n::: {.cell}\n\n```{.r .cell-code}\nggplot(df, aes(Duration_sec)) +\n  geom_histogram(bins = 40) +\n  theme_minimal() +\n  labs(\n    title = \"Distribution of Track Lengths\",\n    x = \"Track Duration (seconds)\",\n    y = \"Count\"\n  )\n```\n\n::: {.cell-output-display}\n![](Quarto_website_files/figure-html/unnamed-chunk-6-1.png){width=672}\n:::\n:::\n\n\n\n::: {.cell}\n\n```{.r .cell-code}\nggplot(game_summary, aes(era, total_runtime_min)) +\n  geom_boxplot() +\n  theme_minimal() +\n  labs(\n    title = \"Soundtrack Runtime by Era\",\n    x = \"Era\",\n    y = \"Runtime (minutes)\"\n  )\n```\n\n::: {.cell-output-display}\n![](Quarto_website_files/figure-html/unnamed-chunk-7-1.png){width=672}\n:::\n:::\n\n\n# Conclusion \n\nVideo game music has expanded dramatically as technology improved \n\nKey Findings: \n\n- Soundtrack size has increased substantially over time \n- Total runtime has expanded across technological generations \n- Early game relied heavily on short looping musical motifs \n\nThese findings illustrate how technological constraints shaped early video game music and how modern systems enables more complex musical scores \n\n\n\n\n# Future Work \n\nFuture research could explore: \n\n- Audio feature extraction \n- Emotion analysis of game soundtracks \n- Instrumentation and orchestration trends\n\n\n\n",
